{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://and-then-what/schemas/mental-models-index.json",
  "title": "Mental Models Index",
  "description": "Index of mental models with paths and quick introductions",
  "type": "object",
  "required": ["mental_models"],
  "properties": {
    "mental_models": {
      "type": "array",
      "description": "Index entries for each mental model",
      "items": {
        "type": "object",
        "required": ["id", "name", "path", "description"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier (snake_case)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable name"
          },
          "path": {
            "type": "string",
            "description": "Path to the mental model YAML file"
          },
          "description": {
            "type": "string",
            "description": "Quick introduction (from quick_introduction field)"
          }
        }
      }
    }
  }
}
