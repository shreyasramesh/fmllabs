# Required for production
GEMINI_API_KEY=              # https://aistudio.google.com/apikey
NEXT_PUBLIC_APP_URL=         # e.g. https://fmllabs.ai (for extension proxy)
MONGODB_URI=                 # MongoDB Atlas connection string for production
# AES-256-GCM application encryption (32 raw bytes, base64). Generate: openssl rand -base64 32
ENCRYPTION_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional
GEMINI_MODEL=gemini-2.5-flash-lite
CAPACITOR_SERVER_URL=https://www.fmllabs.ai
RESEND_API_KEY=                 # For contact form (https://resend.com)
CONTACT_FROM_EMAIL=             # e.g. mainichi <hello@yourdomain.com> (verify domain at resend.com)
CRON_SECRET=                    # Shared secret for scheduled cron endpoints
ELEVENLABS_API_KEY=          # For text-to-speech (Eleven Flash v2.5)
TRANSCRIBR_API_KEY=         # For YouTube transcript fetch ($0.03/fetch)
MONGODB_MAX_POOL_SIZE=10
MONGODB_HOURLY_RATE=0.027    # Atlas M10 $/hr; or 0.011 for Flex
ADMIN_USER_IDS=             # Comma-separated Clerk user IDs for /admin/analytics
